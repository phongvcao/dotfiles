function! CloseUniteWindow()
    execute ":normal! \<C-c>"
    if ( &filetype ==# 'unite' )
        execute ":UniteClose"
    elseif ( &filetype ==# 'magit' ) || ( &filetype ==# 'GV' ) || ( &filetype ==# 'git' )
        if ( tabpagenr('$') == 1 )
            execute ":qall!"
        elseif ( winnr('$') <= 3 )
            execute ":tabclose"
        endif
    elseif ( expand( '%:p' ) =~ '.*Yank.*' )
        execute 'silent! YRShow'
    endif
endfunction

nnoremap <C-c> :call CloseUniteWindow()<CR>
inoremap <C-c> <C-c>:call CloseUniteWindow()<CR>

