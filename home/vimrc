function! InvokeNeoMRU(...)
    let l:arg = join( a:000, '\\ ' )
    if ( l:arg != '' )
        if ! isdirectory( expand( l:arg ) )
            execute "edit " . l:arg
        else
            execute "silent! Unite -prompt=Open>\\ \\  directory:" . l:arg . " directory_mru buffer file_mru file/async:" . l:arg . " file/new -buffer-name=Open\\ Files\\ and\\ Directories"
        endif
    else
        execute "silent! Unite -prompt=Open>\\ \\  directory directory_mru buffer file_mru file/async file/new -buffer-name=Open\\ Files\\ and\\ Directories"
    endif
endfunction
