function! CloseUniteWindow()
    execute ":normal! \<C-c>"
    if ( &filetype ==# 'unite' )
        execute ":UniteClose"
    elseif ( &filetype ==# 'magit' ) || ( &filetype ==# 'GV' ) || ( &filetype ==# 'git' )
        if ( tabpagenr('$') == 1 )
            execute ":qall!"
        elseif ( winnr('$') <= 3 )
            execute ":tabclose"
        endif
    elseif ( expand( '%:p' ) =~ '.*Yank.*' )
        execute 'silent! YRShow'
    endif
endfunction

nnoremap <C-c> :call CloseUniteWindow()<CR>
inoremap <C-c> <C-c>:call CloseUniteWindow()<CR>
vnoremap <C-c> <C-c>
snoremap <C-c> <C-c>
xnoremap <C-c> <C-c>

if has( 'clipboard' ) && !exists( '${SSH_CLIENT}' )
    inoremap <expr><C-p> pumvisible() ? "\<C-p>" : '<C-r>+'
    " Paste content of unnamed register to Vim command-mode
    cnoremap <C-p> <C-r>+
    nnoremap <C-p> i<C-r>+<C-c>
    if has("unix")
        let s:uname = system("uname -s")
        if s:uname == "Darwin"
            nnoremap p "+p
        else
            nnoremap p "*p
        endif
    endif
else
    inoremap <expr><C-p> pumvisible() ? "\<C-p>" : '<C-r>"'
    " Paste content of unnamed register to Vim command-mode
