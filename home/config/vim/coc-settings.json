{
  "languageserver": {
    "golang": {
      "command": "~/.go/bin/gopls",
      "rootPatterns": ["go.mod", ".vim/", ".git/", ".hg/"],
      "filetypes": ["go"]
    },
    "clangpp": {
      "command": "/usr/bin/clang++",
      "trace.server": "verbose",
      "filetypes": ["c", "cpp", "objc", "objcpp"]
    }
  },
  "suggest.noselect": false,
}
