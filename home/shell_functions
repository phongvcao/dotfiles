function cat() {
    if [[ -n "$3" ]]; then
        _cat "$3" | sed "$1,$2!d" | gr "^|$1.*|$2.*"
    elif [[ -n "$2" ]]; then
        arg1="$(expr $1 - 10)"
        arg2="$(expr $1 + 10)"
        if [[ "$arg1" -lt 0 ]]; then
            arg2=0
        fi
        _cat "$2" | sed "$arg1,$arg2!d" | gr "^|$1.*"
    elif [[ -n "$1" ]]; then
        _cat "$1"
    fi
}

