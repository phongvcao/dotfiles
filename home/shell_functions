}

function settitle() {
local true_filename="$(command ls | command grep -i $1)"
ffmpeg -i "${true_filename}" -metadata title="$2" -acodec copy -vcodec copy ".temp_${true_filename}"
rm -rf "${true_filename}"
mv ".temp_${true_filename}" "${true_filename}"
}


function setartist() {
