function find() {
if [[ -n $3 ]]; then
    command find "$2" -maxdepth "$3" -mount -iregex ".*$1.*" \
        -exec ls -F -X -L --dereference-command-line-symlink-to-dir \
        --group-directories-first --color -A -d {} \;
else
    if [[ -n $2 ]]; then
        command find "$2" -mount -iregex ".*$1.*" \
            -exec ls -F -X -L --dereference-command-line-symlink-to-dir \
            --group-directories-first --color -A -d {} \;
    else
        if [[ -n $1 ]]; then
            command find . -mount -iregex ".*$1.*" \
                -exec ls -F -X -L --dereference-command-line-symlink-to-dir \
                --group-directories-first --color -A -d {} \;
        else
            command find . -mount -type d \
                -exec ls -F -X -L --dereference-command-line-symlink-to-dir \
                --group-directories-first --color -A -d {} \;
            command find . -mount -type f \
                -exec ls -F -X -L --dereference-command-line-symlink-to-dir \
                --group-directories-first --color -A -d {} \;
        fi
    fi
fi
}

