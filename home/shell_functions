function printDict() {
if [[ $1 == "dirDict" ]]; then
    for key in "${!dirDict[@]}"; do
        printf "\t\$%-20s %s\n" "$key" "${dirDict[$key]}"
    done |
    sort -n -k3

    echo ""
fi
}

