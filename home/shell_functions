function removeLsSuffix() {
    if [[ -n "${BASH_VERSION}" ]]; then
        local var="${1:0:-2}"
    elif [[ -n "${ZSH_VERSION}" ]]; then
        local var="${1[1,-2]}"
    fi
    if [[ -e "$1" ]]; then
        echo "$1"
    elif [[ -e "${var}" ]]; then
        echo "${var}"
    else
        echo "$1"
    fi
}

